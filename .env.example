# ============================================================
#  نمونه‌ی متغیرهای محیطی — «امروز»
#  این فایل را به .env (یا .env.local) کپی کن و مقادیر را پر کن:
#    cp .env.example .env
#  هیچ مقدارِ واقعی/سکرتی اینجا نگذار؛ این فایل در گیت کامیت می‌شود.
#  برای دیپلوی روی آروان به docs/arvan-cron.md نگاه کن.
# ============================================================

# --- دیتابیس (PostgreSQL مستقیم) ---
# محلی:  postgres://postgres:password@localhost:5432/emroz
# آروان: مقداری که Arvan در پنلِ DBaaS می‌دهد (بدونِ sslmode=require — آروان TLS ندارد)
DATABASE_URL=postgres://user:password@host:5432/dbname

# --- نشست (Session) ---
# یک رشته‌ی تصادفیِ طولانی. تولید: openssl rand -base64 48
SESSION_SECRET=

# --- اسمِ اپ ---
NEXT_PUBLIC_APP_NAME=امروز

# --- آدرسِ پایه‌ی سایت ---
# در پروداکشن حتماً دامنه‌ی واقعی (وگرنه callbackِ پرداخت می‌شکند).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- پیامک SMS.ir (ورود با کد یک‌بارمصرف) ---
SMSIR_API_KEY=
SMSIR_LINE=
SMSIR_TEMPLATE_ID=
SMSIR_TEMPLATE_PARAM=Code

# --- هوش مصنوعی (هر ارائه‌دهنده‌ی OpenAI-compatible) ---
# پیش‌فرض OpenRouter است (https://openrouter.ai/keys)
# روی پروداکشنِ آروان به gateway آروان سوییچ کن تا از فیلترینگ رد نشوی و سرعت بالا بیاید:
#   OPENROUTER_BASE_URL=https://arvancloudai.ir/gateway/models/GPT-5.5/<TOKEN>
#   OPENROUTER_MODEL=GPT-5.5
# (در آروان مدل و کلید از پنل AIaaS گرفته می‌شود.)
OPENROUTER_API_KEY=
# اختیاری — base URL بدون /v1 (به‌طور خودکار /v1/chat/completions ضمیمه می‌شود)
OPENROUTER_BASE_URL=https://openrouter.ai/api
# اختیاری — پیش‌فرض openai/gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- پرداخت زیبال ---
ZIBAL_MERCHANT_ID=
# تست = 1 ، پروداکشن = 0
ZIBAL_SANDBOX=0

# --- نوتیفیکیشنِ وب (Web Push / VAPID) ---
# کلیدها را با web-push generate-vapid-keys بساز. کلیدِ عمومی هم سرور و هم کلاینت لازم است.
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.ir

# --- مدیر (Admin) ---
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- کران‌ها (notify / reconcile / cost-guard) ---
# همه‌ی مسیرهای /api/cron با هدرِ Authorization: Bearer <CRON_SECRET> احراز می‌شوند.
# سرویسِ کرونِ deploy/cron باید APP_URL و همین CRON_SECRET را داشته باشد.
CRON_SECRET=

# --- کنترلِ هزینه و ضدِسوءاستفاده (اختیاری — همگی پیش‌فرضِ امن دارند) ---
# سقفِ سختِ کلِ فراخوانیِ AI در ۲۴ ساعت (۰ = خاموش). حتی بدونِ کرون فعال است.
AI_GLOBAL_DAILY_CAP=5000
# سقفِ ساختِ کاربرِ مهمان از هر IP.
GUEST_PER_HOUR=5
GUEST_PER_DAY=20
# بازه‌ی مجازِ ارسالِ پیامک به وقتِ تهران (خطِ تبلیغاتی شب اجازه ندارد).
# با خطِ خدماتی/تراکنشی: 0 و 24 بگذار تا قفلِ شبانه باز شود.
OTP_OPEN_HOUR=8
OTP_CLOSE_HOUR=22

# --- اکانتِ تست (فقط توسعه؛ در NODE_ENV=production بی‌اثر است — در پروداکشن ستش نکن) ---
# TEST_PHONE=09120000000
# TEST_OTP_CODE=12345
